    "bench": "npm run bench --workspaces --if-present"
  },
  "devDependencies": {
    "fast-xml-parser": "^4.5.0",
    "js-yaml": "^4.1.1",
    "node-gyp": "^12.2.0",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  }
}
